{
  "name": "adonis-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Governed, durable-backed AI agent (chat + tool-calling + governance) for AdonisJS — part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-agent.git"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "release": "pnpm --filter './packages/*' build && changeset publish",
    "version-packages": "changeset version && node scripts/sync-version.mjs && biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "unplugin-swc": "^1.5.9",
    "@swc/core": "^1.15.40",
    "vitest": "^3.0.0"
  }
}
