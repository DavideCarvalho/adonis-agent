      "optional": true
    },
    "@adonis-agora/telescope": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonis-agora/durable": "^0.8.0",
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "ai": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "luxon": "^3.4.0",
    "node-sql-parser": "^5.3.0",
    "react": "^19.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
