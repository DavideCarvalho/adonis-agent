    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js",
      "default": "./dist/src/types.js"
    },
    "./agent_provider": {
      "types": "./dist/providers/agent_provider.d.ts",
      "import": "./dist/providers/agent_provider.js",
      "default": "./dist/providers/agent_provider.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    },
    "./stores/lucid": {
      "types": "./dist/src/stores/lucid.d.ts",
      "import": "./dist/src/stores/lucid.js",
      "default": "./dist/src/stores/lucid.js"
    },
    "./data": {
      "types": "./dist/src/data/index.d.ts",
      "import": "./dist/src/data/index.js",
      "default": "./dist/src/data/index.js"
    },
    "./rag-media": {
      "types": "./dist/src/rag-media/index.d.ts",
      "import": "./dist/src/rag-media/index.js",
      "default": "./dist/src/rag-media/index.js"
    },
    "./hooks/tools": {
      "types": "./dist/src/hooks/tools.d.ts",
      "import": "./dist/src/hooks/tools.js",
      "default": "./dist/src/hooks/tools.js"
    },
    "./telescope": {
      "types": "./dist/src/telescope/index.d.ts",
      "import": "./dist/src/telescope/index.js",
      "default": "./dist/src/telescope/index.js"
    },
    "./client": {
      "types": "./dist/src/client/index.d.ts",
      "import": "./dist/src/client/index.js",
      "default": "./dist/src/client/index.js"
    },
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "import": "./dist/src/react/index.js",
      "default": "./dist/src/react/index.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/config dist/stubs/database/migrations && cp stubs/config/agent.stub dist/stubs/config/agent.stub && cp -r stubs/database/migrations/. dist/stubs/database/migrations/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "peerDependencies": {
    "@adonis-agora/authz": "^0.4.0",
    "@adonis-agora/diagnostics": "^0.1.0",
    "@adonis-agora/durable": "^0.8.0",
    "@adonis-agora/telescope": "^0.4.0",
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.0",
    "@adonisjs/redis": "^9.2.0",
    "ai": "^7.0.0",
    "node-sql-parser": "^5.3.0",
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
