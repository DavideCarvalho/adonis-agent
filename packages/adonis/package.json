{
  "name": "@adonis-agora/agent",
  "version": "0.13.3",
  "description": "Governed, durable-backed AI agent (chat + tool-calling + governance) for AdonisJS — part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-agent.git",
    "directory": "packages/adonis"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/src/ai-sdk/index.d.ts",
      "import": "./dist/src/ai-sdk/index.js",
      "default": "./dist/src/ai-sdk/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js",
      "default": "./dist/src/testing/index.js"
    },
    "./durable": {
      "types": "./dist/src/durable/index.d.ts",
      "import": "./dist/src/durable/index.js",
      "default": "./dist/src/durable/index.js"
    },
    "./authz": {
      "types": "./dist/src/authz/index.d.ts",
