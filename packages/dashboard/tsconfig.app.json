{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false
  },
  "include": ["src/app/**/*.ts", "src/app/**/*.tsx", "src/client/**/*.ts"],
  "exclude": ["dist/**", "node_modules"]
}
